[library]
include_dirs = live_unbundler

[bootstrap]
main_collection = /main/main.collectionc

[script]
shared_state = 1

[display]
width = 960
height = 640
high_dpi = 1

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = defold_live_unbundler
bundle_identifier = com.defold_live_unbundler
minimum_log_level = 0
dependencies#0 = https://github.com/britzl/ludobits/archive/refs/tags/7.5.0.zip

[liveupdate]
mount_on_start = 0

[graphics]
texture_profiles = /graphics/main.texture_profiles
